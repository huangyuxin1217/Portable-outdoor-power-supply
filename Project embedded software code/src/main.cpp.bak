#include <Arduino.h>
#include <WiFi.h>
#include <PubSubClient.h>
#include <driver/i2s.h>
#include "oled.h"
#include "wifi_server.h"

// WiFi配置
const char* ssid = "zmy";
const char* password = "zmy060521";

// MQTT配置
const char* mqtt_server = "broker.emqx.io"; // 使用公共MQTT服务器测试
const char* mqtt_topic = "esp32/audio/test";

WiFiClient espClient;
PubSubClient client(espClient);

// I2S配置
#define I2S_WS 25
#define I2S_SD 34
#define I2S_SCK 26
#define I2S_PORT I2S_NUM_0
#define BUFFER_LEN 1024

int16_t sBuffer[BUFFER_LEN];

void i2s_install() {
  const i2s_config_t i2s_config = {
    .mode = i2s_mode_t(I2S_MODE_MASTER | I2S_MODE_RX),
    .sample_rate = 16000,
    .bits_per_sample = I2S_BITS_PER_SAMPLE_16BIT,
    .channel_format = I2S_CHANNEL_FMT_ONLY_LEFT,
    .communication_format = i2s_comm_format_t(I2S_COMM_FORMAT_I2S | I2S_COMM_FORMAT_I2S_MSB),
    .intr_alloc_flags = ESP_INTR_FLAG_LEVEL1,
    .dma_buf_count = 4,
    .dma_buf_len = BUFFER_LEN,
    .use_apll = false
  };

  i2s_driver_install(I2S_PORT, &i2s_config, 0, NULL);
}

void i2s_setpin() {
  const i2s_pin_config_t pin_config = {
    .bck_io_num = I2S_SCK,
    .ws_io_num = I2S_WS,
    .data_out_num = I2S_PIN_NO_CHANGE,
    .data_in_num = I2S_SD
  };

  i2s_set_pin(I2S_PORT, &pin_config);
}

void mqttCallback(char* topic, byte* payload, unsigned int length) {
  // 简单的回调，不需要做太多事情
}

void reconnect() {
  while (!client.connected()) {
    Serial.print("Attempting MQTT connection...");
    String clientId = "ESP32Client-";
    clientId += String(random(0xffff), HEX);
    if (client.connect(clientId.c_str())) {
      Serial.println("connected");
      client.subscribe(mqtt_topic);
    } else {
      Serial.print("failed, rc=");
      Serial.print(client.state());
      Serial.println(" try again in 5 seconds");
      delay(5000);
    }
  }
}

void setup() {
  Serial.begin(115200);
  
  // 初始化OLED
  OLED_Init();
  OLED_NewFrame();
  OLED_PrintASCIIString(0, 0, "Mic Test Mode", &afont8x6, OLED_COLOR_NORMAL);
  OLED_ShowFrame();

  // 连接WiFi
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi connected");
  
  OLED_NewFrame();
  OLED_PrintASCIIString(0, 0, "WiFi OK", &afont8x6, OLED_COLOR_NORMAL);
  OLED_PrintASCIIString(0, 10, WiFi.localIP().toString().c_str(), &afont8x6, OLED_COLOR_NORMAL);
  OLED_ShowFrame();

  // 初始化MQTT
  client.setServer(mqtt_server, 1883);
  client.setCallback(mqttCallback);

  // 初始化Web服务器 (复用wifi_server.cpp中的逻辑)
  WebServer_Init();

  // 初始化I2S
  i2s_install();
  i2s_setpin();
  i2s_start(I2S_PORT);
}

void loop() {
  if (!client.connected()) {
    reconnect();
  }
  client.loop();
  
  // 处理Web服务器请求
  WebServer_Handle();

  size_t bytesIn = 0;
  esp_err_t result = i2s_read(I2S_PORT, &sBuffer, BUFFER_LEN * sizeof(int16_t), &bytesIn, portMAX_DELAY);

  if (result == ESP_OK && bytesIn > 0) {
    // 计算音量大小用于显示
    long sum = 0;
    for (int i = 0; i < bytesIn / 2; i++) {
      sum += abs(sBuffer[i]);
    }
    float average = sum / (bytesIn / 2.0);
    
    // 更新Web服务器中的麦克风数据
    SetMicLevel((int)average);
    
    // 在串口绘图仪显示波形
    Serial.println(sBuffer[0]); 

    // 在OLED显示音量条
    static unsigned long lastDraw = 0;
    if (millis() - lastDraw > 100) {
      OLED_NewFrame();
      OLED_PrintASCIIString(0, 0, "Mic Level:", &afont8x6, OLED_COLOR_NORMAL);
      
      // 绘制音量条
      int barWidth = map((long)average, 0, 5000, 0, 128); // 根据实际噪音调整范围
      if(barWidth > 128) barWidth = 128;
      OLED_DrawFilledRectangle(0, 20, barWidth, 10, OLED_COLOR_NORMAL);
      
      char buf[32];
      snprintf(buf, sizeof(buf), "Val: %d", (int)average);
      OLED_PrintASCIIString(0, 40, buf, &afont8x6, OLED_COLOR_NORMAL);
      
      OLED_ShowFrame();
      lastDraw = millis();
    }

    // 可选：发送数据到MQTT (为了避免阻塞，这里只发送少量数据或特征值)
    // client.publish(mqtt_topic, (uint8_t*)sBuffer, bytesIn); 
  }
}
